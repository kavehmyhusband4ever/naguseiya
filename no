<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Southern Cloud's Star Arrow ♡</title>

<style>
body {
    margin: 0;
    font-family: "Comic Sans MS", cursive, sans-serif;
    display: flex;
    background: linear-gradient(135deg, #ffd6ec, #d6f5ff, #fff0b3);
    overflow-x: hidden;
}

/* Sidebar */
.sidebar {
    width: 200px;
    background: #fff0f6;
    padding: 20px;
    box-shadow: 4px 0 10px rgba(0,0,0,0.1);
    min-height: 100vh;
}

.sidebar h2 {
    color: #ff69b4;
}

.sidebar button {
    background: #ffb6c1;
    border: none;
    padding: 10px;
    margin-top: 10px;
    border-radius: 15px;
    cursor: pointer;
    width: 100%;
    font-weight: bold;
}

.sidebar button:hover {
    background: #ff69b4;
    color: white;
}

/* Main */
.main {
    flex: 1;
    text-align: center;
    padding: 20px;
}

header {
    font-size: 2em;
    color: #ff69b4;
    text-shadow: 2px 2px white;
}

input[type="file"] {
    margin: 20px;
    padding: 10px;
    border-radius: 20px;
    border: 2px dashed #ffb6c1;
    background: white;
}

.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
    padding: 20px;
}

.photo-card {
    position: relative;
}

.photo-card img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
}

.delete-btn {
    position: absolute;
    top: 5px;
    right: 5px;
    background: #ff69b4;
    border: none;
    border-radius: 50%;
    width: 25px;
    height: 25px;
    color: white;
    cursor: pointer;
    font-weight: bold;
}

/* Floating hearts */
.heart {
    position: fixed;
    color: pink;
    font-size: 20px;
    animation: float 6s linear infinite;
}

@keyframes float {
    0% { transform: translateY(100vh); opacity: 1; }
    100% { transform: translateY(-10vh); opacity: 0; }
}
</style>
</head>

<body>

<div class="sidebar">
    <h2>🎀 Menu</h2>
    <button onclick="clearGallery()">Clear All</button>
</div>

<div class="main">
    <header>🎀🗡 Nagumo Yoichi x Seiya Amiyama Gallery ♡</header>
    <input type="file" id="imageUpload" accept="image/*" multiple>
    <div class="gallery" id="gallery"></div>
</div>

<script>
const uploadInput = document.getElementById("imageUpload");
const gallery = document.getElementById("gallery");

let images = JSON.parse(localStorage.getItem("kawaiiGallery")) || [];

window.onload = function() {
    images.forEach(src => addImageToGallery(src));
};

uploadInput.addEventListener("change", function() {
    const files = this.files;
    for (let i = 0; i < files.length; i++) {
        const reader = new FileReader();
        reader.onload = function(e) {
            images.push(e.target.result);
            localStorage.setItem("kawaiiGallery", JSON.stringify(images));
            addImageToGallery(e.target.result);
        }
        reader.readAsDataURL(files[i]);
    }
});

function addImageToGallery(src) {
    const card = document.createElement("div");
    card.className = "photo-card";

    const img = document.createElement("img");
    img.src = src;

    const delBtn = document.createElement("button");
    delBtn.innerHTML = "×";
    delBtn.className = "delete-btn";
    delBtn.onclick = function() {
        images = images.filter(image => image !== src);
        localStorage.setItem("kawaiiGallery", JSON.stringify(images));
        card.remove();
    };

    card.appendChild(img);
    card.appendChild(delBtn);
    gallery.appendChild(card);
}

function clearGallery() {
    if(confirm("Clear all photos? 🌸")) {
        images = [];
        localStorage.removeItem("kawaiiGallery");
        gallery.innerHTML = "";
    }
}

function createHeart() {
    const heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = "💖";
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.fontSize = (Math.random() * 20 + 10) + "px";
    document.body.appendChild(heart);
    setTimeout(() => heart.remove(), 6000);
}
setInterval(createHeart, 800);
</script>

</body>
</html>
